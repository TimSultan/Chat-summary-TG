# Get these from https://my.telegram.org/apps (log in, "API development tools", create an app)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Name of the local session file Telethon creates after your first interactive login.
# Keep it secret -- it grants full access to your Telegram account, like a saved login.
TELEGRAM_SESSION=tg_summary_session

# Alternative to TELEGRAM_SESSION, for hosts with no persistent disk (Railway, etc.):
# a portable session string instead of a file. Generate it locally with
# `python generate_session_string.py`, then set it as an env var on the host -- the
# deployed listener starts already logged in, no interactive step or volume needed.
# If set, this takes priority over TELEGRAM_SESSION. Leave blank for local use.
TELEGRAM_SESSION_STRING=

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Any chat-capable model -- pick from the dropdown in gui.py, or set one directly here.
# gpt-4o / gpt-4o-mini are the old, slower tier; gpt-5.4-mini is the current fast/cheap
# default, gpt-5.5 is the best-quality flagship (similar latency to 5.4), gpt-5.4-nano is
# fastest/cheapest for quiet chats. See config.py's RECOMMENDED_MODELS for the full list.
OPENAI_MODEL=gpt-5.4-mini

# IANA timezone used for calendar-day boundaries and displayed/stored timestamps.
# This is deliberately explicit so a London-hosted deployment still runs on Moscow time.
APP_TIMEZONE=Europe/Moscow

# --- listener.py only (the mention-triggered auto-reply bot) ---

# Which /summary request pipeline the listener uses: "v2" (default) routes the request
# through intent_v2.py (date range + optional focus person + a cleaned-up question only)
# and answers it in one freeform step via responder_v2.py. "v1" uses the older
# intent.py/summarizer.py pipeline, which also extracts a separate topic/length hint and
# applies a larger rule-based prompt. Kept switchable for comparison/rollback. Only
# affects this account's own /summary handling -- bot_listener.py (below) always uses v2.
SUMMARY_PIPELINE_VERSION=v2

# Optional: run a separate bot account (bot_listener.py) that answers /summary as itself
# instead of your personal account, over Telegram's Bot HTTP API. Get a token from
# @BotFather (/newbot), then:
#   1. Message @BotFather -> /setprivacy -> select your bot -> Disable. Without this, a
#      bot in a group only sees messages that @mention/reply to it -- but "/summary" as a
#      literal slash-command is actually visible either way (Telegram always delivers
#      commands to bots regardless of privacy mode), so this mainly matters if you use a
#      non-slash trigger keyword in LISTENER_TRIGGER_KEYWORDS above.
#   2. Add the bot to each chat listed in LISTENER_ALLOWED_CHATS (it has no access to a
#      chat's history from before it joined, and no access at all to chats it isn't in).
#   3. Set TELEGRAM_BOT_TOKEN below and start listener.py as usual -- it detects the
#      token and runs bot_listener.py's long-polling loop alongside itself in the same
#      process, using this account's already-connected Telethon session (TELEGRAM_API_ID/
#      HASH/SESSION above) to fetch history, since bots can't fetch history themselves.
# Once set, this account's own /summary handling turns off automatically (to avoid two
# replies to the same message) -- roast and save keep working from this account as before.
# Leave blank to keep everything on this account only, as before.
TELEGRAM_BOT_TOKEN=

# Comma-separated allowlist of chats (by @username, exact title, or numeric ID) the listener
# will respond in. STRONGLY recommended: leaving this empty means the bot will respond to
# summary requests from anyone in any chat you're in, spending your OpenAI budget for them.
# bot_listener.py only: a private chat (DM) with the bot itself is ALWAYS allowed
# regardless of this list -- it's a legitimate input channel, not "any random chat". If
# this list contains exactly one entry, that chat also becomes the data source used for
# any /summary or roast request that arrives via DM (a DM has no group history of its
# own to fetch, so it needs a fixed target to pull from) -- with zero or multiple entries
# there's no unambiguous default, and a DM request will just say so instead of guessing.
LISTENER_ALLOWED_CHATS=

# Comma-separated keywords that trigger a summary request, like a slash-command -- no
# @mention or reply-to-you needed, from anyone, in any allowed chat (case-insensitive).
# Two more triggers always work too, regardless of this list: your first name plus the
# word "summary" in one message, or replying to one of your own messages with a message
# containing "summary".
LISTENER_TRIGGER_KEYWORDS=/summary

# Every summary enquiry is retained in one FIFO queue. The first starts immediately;
# after each enquiry finishes, the worker waits this many seconds before starting next.
SUMMARY_QUEUE_DELAY_SECONDS=20

# Currently disabled in code (listener.py and bot_listener.py both force the roast
# trigger to never match), so these ROAST_* settings have no effect right now -- kept so
# turning it back on doesn't also require re-adding config. When enabled, this
# comma-separated list of keywords triggers a "roast me" flow: whoever sends one gets
# asked to confirm ("Ты точно хочешь прожарку? поставь реакцию для подтверждения"), and
# only a reaction from that same person on that prompt actually generates the roast (in
# Russian, 5 points, based on their own messages from the last ROAST_LOOKBACK_DAYS
# days). Same allowlist rules as the summary trigger above.
ROAST_TRIGGER_KEYWORDS=прожарь меня

# How many days back (including today) to pull the requester's own messages from for
# the roast command.
ROAST_LOOKBACK_DAYS=30

# Caps how many of the requester's own messages (most recent) actually get sent to
# OpenAI for a roast. Generation map-reduces the transcript into chunks with one
# sequential OpenAI call per chunk, so an active poster's full month can otherwise mean
# dozens of blocking calls (minutes of silence before anything is sent). 400 keeps most
# people to a handful of calls; lower it for faster/cheaper roasts, raise it to consider
# more history at the cost of a longer wait.
ROAST_MAX_MESSAGES=400

# Word that, when a message starting with it is sent by you as a reply to another
# message, reposts that replied-to message (photo, video, any media, or just text) to
# SAVE_CHANNEL below -- any text after the trigger word is appended as a caption. Your
# own trigger message gets a reaction and is then deleted a few seconds later. Unlike
# the summary/roast triggers, this only ever fires for messages YOU send (never other
# chat members) and ignores LISTENER_ALLOWED_CHATS, since it doesn't touch the OpenAI
# budget.
SAVE_TRIGGER_KEYWORD=сохрани

# Channel (by @username, without the @) that SAVE_TRIGGER_KEYWORD reposts to. You must
# already be a member/admin of it. Leave blank to disable the save trigger.
SAVE_CHANNEL=papka_pokrasa

# Optional, off by default. When on, the chat occasionally gets one unprompted short
# conversational remark (joke.py) instead of only ever replying when asked. The JOKE_*
# names are retained for compatibility, but the model is explicitly told not to force a
# joke: it should naturally continue the conversation in the chat's own style, using
# sarcasm only when it fits. Requires
# TELEGRAM_BOT_TOKEN AND a non-empty LISTENER_ALLOWED_CHATS (remarks never default to
# "everywhere" the way summary does) -- always sent via the bot account, never your
# personal one.
#
# Fires purely off real message volume, not a timer: JOKE_ACTIVITY_MIN_MESSAGES qualifying
# messages have to land (in a rolling per-chat buffer) before it's even considered. The
# effective minimum is 20 even if configured lower: generation always gets the newest 20
# messages, with 15 labelled as background and the final 5 as the conversation to answer.
# A quiet/sleeping chat structurally can't trigger it -- it isn't a matter of waiting, the
# buffer just never fills. Once full, it fires if the cooldown has passed (see below) and a
# random roll under JOKE_FIRE_PROBABILITY hits; a miss doesn't reset anything, so the very
# next message tries again instead of needing a whole new buffer.
JOKE_ENABLED=false
JOKE_ACTIVITY_MIN_MESSAGES=20
JOKE_FIRE_PROBABILITY=0.35

# Cooldown only ever applies after an actual remark is sent (chosen randomly in this range
# each time, so it's not a flat interval) -- never after the model declines (see below),
# which just costs another full buffer of messages, not a timer.
JOKE_COOLDOWN_MIN_SECONDS=1800
JOKE_COOLDOWN_MAX_SECONDS=3600

# If a posted remark gets this many reactions (any emoji, from distinct people), its chat's
# cooldown is pulled in to JOKE_REACTION_COOLDOWN_SECONDS from when it was posted (only if
# that's actually sooner than what was already rolled) -- a remark that lands well earns a
# faster shot at the next one.
JOKE_REACTION_THRESHOLD=3
JOKE_REACTION_COOLDOWN_SECONDS=1800

# On top of all of the above, nothing reviews a remark before it posts, so the model itself
# is instructed to decline for anything that isn't actually a natural moment, including
# heated arguments and sensitive personal topics.

# Send these as a DM to the bot to manually generate a remark in the home chat (see
# LISTENER_ALLOWED_CHATS -- needs exactly one entry, same as DM /summary requests),
# bypassing the buffer/cooldown/random-roll gates above entirely (it's an explicit ask) --
# the model can still decline, though, and once actually posted it still starts the normal
# cooldown, same as an automatic remark. JOKE_MANUAL_TRIGGER_KEYWORD posts straight to the
# chat; JOKE_MANUAL_PREVIEW_KEYWORD sends it back to the DM first with a button to confirm
# before it goes out -- handy for trying it without risking a dud landing in the group.
JOKE_MANUAL_TRIGGER_KEYWORD=пошути
JOKE_MANUAL_PREVIEW_KEYWORD=пошути превью

# Every remark (automatic or manual) is given a compact "flavor profile" of the chat --
# its language mix, message length/structure, casing, punctuation, slang,
# conversational rhythm, recurring context, and humor where relevant -- built by
# chat_profile.py from a few days of the already-cached transcript, so the output fits the
# room's normal speech instead of reading like a generic bot joke. Regenerated (one OpenAI
# call) at most once per JOKE_PROFILE_TTL_SECONDS, not on every remark, and capped to the
# most recent JOKE_PROFILE_MAX_MESSAGES across JOKE_PROFILE_LOOKBACK_DAYS -- both keep this
# cheap regardless of how chatty the room is.
JOKE_PROFILE_LOOKBACK_DAYS=3
JOKE_PROFILE_TTL_SECONDS=86400
JOKE_PROFILE_MAX_MESSAGES=1000

# On by default (requires TELEGRAM_BOT_TOKEN). When someone comments on the bot's last
# /summary answer or remark -- praise, mockery, whatever -- without necessarily @mentioning
# it or replying directly (just chat moving on and remarking on it), the bot gets to
# reply once in the chat's normal style, without being forced to joke or clap back (see
# followup.py). Watches at most FOLLOWUP_WINDOW_MESSAGES messages after
# each response looking for that -- if nothing shows up within that window, it stays
# quiet. As with remarks, nothing reviews this before it posts, so the model can also
# decide none of those messages were actually about it and skip replying. Always sent
# via the bot account, never your personal one. Set to false to turn this off.
#
# Doesn't check on every single message -- only every FOLLOWUP_CHECK_EVERY_MESSAGES
# messages (the window boundary itself is always checked too, regardless of where that
# falls), trading a bit of responsiveness for a fraction of the OpenAI calls: with the
# defaults below, that's 3 calls per watched response (at message 5, 10, 15) instead of
# up to 15.
FOLLOWUP_ENABLED=true
FOLLOWUP_WINDOW_MESSAGES=15
FOLLOWUP_CHECK_EVERY_MESSAGES=5

# On by default. Tracks per-user activity (messages, characters, media, replies, active
# days, hourly histogram -- see stats.py) once per calendar day, computed from the same
# per-day transcript cache everything else already uses -- no extra Telegram load beyond
# making sure that day's cache is complete before it closes out (see
# telegram_fetch.ensure_day_finalized). Needs a non-empty LISTENER_ALLOWED_CHATS, same as
# jokes -- stats are tracked per named chat, there's no "everywhere" fallback.
#
# Powers two commands, in any allowed chat, from anyone (works from either account,
# whichever currently handles /summary -- see TELEGRAM_BOT_TOKEN above):
#   /top day|week|month|year|all  -- top STATS_TOP_LIMIT people by a simple points score
#                             (+1/message, +1/photo-or-video message, +1/reply,
#                             +5/distinct active day, +100/message tagged #япокрасил with
#                             an actual photo attached -- always recomputed on demand,
#                             never stored, so tuning the point values later needs no
#                             backfill; "all" is the whole tracked history, not a rolling
#                             window; "day" is just an alias for "today")
#   /stat [username]       -- one person's all-time tracked totals, incl. raw figurines-
#                             painted count (yourself if no username is given); "/stat
#                             day|week|month|year|all" instead shows the same leaderboard
#                             as the equivalent /top
# Set to false to turn both commands and the daily tracking off.
STATS_ENABLED=true

# How many people /top (and /top-style /stat lookups) show.
STATS_TOP_LIMIT=10

# On startup (and, in effect, every midnight after), how many past days to check for
# unrecorded stats and back-fill -- covers downtime (a restart that missed one or more
# midnights) without re-scanning a chat's entire history every time. Already-recorded
# days within this window cost nothing but a file-existence check (see
# stats.is_recorded), so raising this is cheap UNLESS a chat has no transcript cache at
# all yet for some of those days, in which case each such day triggers a real Telegram
# history fetch.
STATS_CATCHUP_DAYS=7

# Optional. Where the transcript cache, Q&A history, and per-day stats files (all under
# cache/, plus history/) are written. Defaults to the current directory -- fine locally.
# On a host with no persistent disk by default (Railway, etc.), point this at a mounted
# Volume's path (e.g. /data) so those survive restarts/redeploys instead of resetting
# each time. Not required for the app to work -- without it, they just start empty after
# every restart.
DATA_DIR=
