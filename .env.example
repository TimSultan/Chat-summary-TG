# Get these from https://my.telegram.org/apps (log in, "API development tools", create an app)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Name of the local session file Telethon creates after your first interactive login.
# Keep it secret -- it grants full access to your Telegram account, like a saved login.
TELEGRAM_SESSION=tg_summary_session

# Alternative to TELEGRAM_SESSION, for hosts with no persistent disk (Railway, etc.):
# a portable session string instead of a file. Generate it locally with
# `python generate_session_string.py`, then set it as an env var on the host -- the
# deployed listener starts already logged in, no interactive step or volume needed.
# If set, this takes priority over TELEGRAM_SESSION. Leave blank for local use.
TELEGRAM_SESSION_STRING=

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Any chat-capable model -- pick from the dropdown in gui.py, or set one directly here.
# gpt-4o / gpt-4o-mini are the old, slower tier; gpt-5.4-mini is the current fast/cheap
# default, gpt-5.5 is the best-quality flagship (similar latency to 5.4), gpt-5.4-nano is
# fastest/cheapest for quiet chats. See config.py's RECOMMENDED_MODELS for the full list.
OPENAI_MODEL=gpt-5.4-mini

# --- listener.py only (the mention-triggered auto-reply bot) ---

# Comma-separated allowlist of chats (by @username, exact title, or numeric ID) the listener
# will respond in. STRONGLY recommended: leaving this empty means the bot will respond to
# summary requests from anyone in any chat you're in, spending your OpenAI budget for them.
LISTENER_ALLOWED_CHATS=

# Comma-separated keywords that trigger a summary request, like a slash-command -- no
# @mention or reply-to-you needed, from anyone, in any allowed chat (case-insensitive).
# Two more triggers always work too, regardless of this list: your first name plus the
# word "summary" in one message, or replying to one of your own messages with a message
# containing "summary".
LISTENER_TRIGGER_KEYWORDS=/summary

# Minimum seconds between two triggered replies in the same chat, to avoid spam/abuse.
# On cooldown, the listener replies "Спросите через X минут" (auto-deleted after 10s)
# instead of silently ignoring the request.
LISTENER_COOLDOWN_SECONDS=180

# Comma-separated keywords that trigger a "roast me" flow: whoever sends one gets asked
# to confirm ("Ты точно хочешь прожарку? поставь реакцию для подтверждения"), and only a
# reaction from that same person on that prompt actually generates the roast (in
# Russian, 5 points, based on their own messages from the last ROAST_LOOKBACK_DAYS
# days). Same allowlist/cooldown rules as the summary trigger above.
ROAST_TRIGGER_KEYWORDS=прожарь меня

# How many days back (including today) to pull the requester's own messages from for
# the roast command.
ROAST_LOOKBACK_DAYS=30

# Caps how many of the requester's own messages (most recent) actually get sent to
# OpenAI for a roast. Generation map-reduces the transcript into chunks with one
# sequential OpenAI call per chunk, so an active poster's full month can otherwise mean
# dozens of blocking calls (minutes of silence before anything is sent). 400 keeps most
# people to a handful of calls; lower it for faster/cheaper roasts, raise it to consider
# more history at the cost of a longer wait.
ROAST_MAX_MESSAGES=400

# Optional. Where the transcript cache (cache/) and Q&A history (history/) are written.
# Defaults to the current directory -- fine locally. On a host with no persistent disk by
# default (Railway, etc.), point this at a mounted Volume's path (e.g. /data) so those
# survive restarts/redeploys instead of resetting each time. Not required for the app to
# work -- without it, the cache/history just start empty after every restart.
DATA_DIR=
